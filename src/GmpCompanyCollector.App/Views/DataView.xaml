<UserControl x:Class="GmpCompanyCollector.App.Views.DataView" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"><DockPanel Margin="8"><StackPanel DockPanel.Dock="Top" Orientation="Horizontal"><TextBox Width="240" Text="{Binding Data.SearchText}" ToolTip="업체명 검색"/><Button Content="전체 선택" Command="{Binding Data.SelectAllCommand}"/><Button Content="선택 해제" Command="{Binding Data.UnselectAllCommand}"/><Button Content="Excel 저장" Command="{Binding Data.ExportExcelCommand}"/><Button Content="CSV 저장" Command="{Binding Data.ExportCsvCommand}"/></StackPanel><TabControl><TabItem Header="업체 목록"><DataGrid ItemsSource="{Binding Data.Companies}"><DataGrid.Columns><DataGridCheckBoxColumn Header="선택" Binding="{Binding IsSelected}"/><DataGridTextColumn Header="업종" Binding="{Binding Induty}"/><DataGridTextColumn Header="업체명" Binding="{Binding Entrps}"/><DataGridTextColumn Header="대표자명" Binding="{Binding Rprsntv}"/><DataGridTextColumn Header="업체허가일자" Binding="{Binding PrmisnDateDisplay}"/><DataGridTextColumn Header="업체허가번호" Binding="{Binding PrmisnNo}"/><DataGridTextColumn Header="공장주소" Binding="{Binding Adres}"/><DataGridTextColumn Header="시·도" Binding="{Binding Sido}"/><DataGridTextColumn Header="시·군·구" Binding="{Binding Sigungu}"/></DataGrid.Columns></DataGrid></TabItem><TabItem Header="제조소 상세"><DataGrid ItemsSource="{Binding Data.Factories}"><DataGrid.Columns><DataGridCheckBoxColumn Header="선택" Binding="{Binding IsSelected}"/><DataGridTextColumn Header="업체명" Binding="{Binding Entrps}"/><DataGridTextColumn Header="업종" Binding="{Binding Induty}"/><DataGridTextColumn Header="업체허가번호" Binding="{Binding PrmisnNo}"/><DataGridTextColumn Header="대표자명" Binding="{Binding Rprsntv}"/><DataGridTextColumn Header="공장일련번호" Binding="{Binding Sn}"/><DataGridTextColumn Header="공장명" Binding="{Binding FctryNm}"/><DataGridTextColumn Header="공장전화번호" Binding="{Binding Telno}"/><DataGridTextColumn Header="통합공장주소" Binding="{Binding CombinedFactoryAddress}"/><DataGridTextColumn Header="시·도" Binding="{Binding Sido}"/></DataGrid.Columns></DataGrid></TabItem></TabControl></DockPanel></UserControl>
