<UserControl x:Class="GmpCompanyCollector.App.Views.StatisticsView" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"><StackPanel Margin="16"><TextBlock FontSize="18" FontWeight="Bold" Text="통계"/><TextBlock Text="표 형태 통계는 수집 데이터 기준으로 계산됩니다. Excel 내보내기에는 업종별/지역별 통계 시트가 포함됩니다."/><UniformGrid Columns="2"><TextBlock Text="전체 업체 레코드 수"/><TextBlock Text="{Binding Statistics.Basic.CompanyRecordCount}"/><TextBlock Text="전체 제조소 수"/><TextBlock Text="{Binding Statistics.Basic.FactoryCount}"/><TextBlock Text="주소가 있는 제조소 수"/><TextBlock Text="{Binding Statistics.Basic.FactoryWithAddressCount}"/><TextBlock Text="전화번호가 있는 제조소 수"/><TextBlock Text="{Binding Statistics.Basic.FactoryWithPhoneCount}"/></UniformGrid></StackPanel></UserControl>
