<UserControl x:Class="GmpCompanyCollector.App.Views.SettingsView" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"><StackPanel Margin="16"><TextBlock FontWeight="Bold" FontSize="18" Text="인증 설정"/><TextBlock Text="서비스키"/><TextBox Text="{Binding Settings.ServiceKey,UpdateSourceTrigger=PropertyChanged}"/><CheckBox Content="인증키 기억하기" IsChecked="{Binding Settings.RememberKey}"/><ComboBox ItemsSource="{Binding Settings.KeyModes}" SelectedItem="{Binding Settings.KeyMode}"/><StackPanel Orientation="Horizontal"><Button Content="API 연결 테스트" Command="{Binding Settings.TestCommand}"/><Button Content="저장된 인증키 삭제" Command="{Binding Settings.DeleteSavedKeyCommand}"/></StackPanel><TextBlock TextWrapping="Wrap" Text="{Binding Settings.ConnectionMessage}"/></StackPanel></UserControl>
