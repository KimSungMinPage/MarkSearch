<UserControl x:Class="GmpCompanyCollector.App.Views.CollectionView" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"><StackPanel Margin="16"><TextBlock FontSize="18" FontWeight="Bold" Text="데이터 수집"/><ComboBox SelectedItem="{Binding Collection.Options.Kind}" ItemsSource="{Binding CollectionKindValues}"/><TextBox Text="{Binding Collection.Options.Induty}" ToolTip="업종"/><TextBox Text="{Binding Collection.Options.Entrps}" ToolTip="업체명"/><TextBox Text="{Binding Collection.Options.PrmisnDt}" ToolTip="업체허가일자 YYYYMMDD"/><TextBox Text="{Binding Collection.Options.PrmisnNo}" ToolTip="업체허가번호"/><ComboBox ItemsSource="{Binding Collection.RowOptions}" SelectedItem="{Binding Collection.Options.NumOfRows}"/><StackPanel Orientation="Horizontal"><Button Content="수집 시작" Command="{Binding Collection.StartCommand}"/><Button Content="수집 취소" Command="{Binding Collection.CancelCommand}"/><Button Content="결과 초기화" Command="{Binding Collection.ClearCommand}"/></StackPanel><TextBlock Text="{Binding Collection.Progress.CurrentTask}"/><ProgressBar Height="22" Minimum="0" Maximum="100" Value="{Binding Collection.Progress.Percent}"/><TextBlock><Run Text="현재 페이지: "/><Run Text="{Binding Collection.Progress.CurrentPage}"/><Run Text=" / "/><Run Text="{Binding Collection.Progress.TotalPages}"/></TextBlock></StackPanel></UserControl>
